# ===== MENTOR - Configuración =====

# -- General --
APP_NAME=Mentor
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

# -- API --
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
CORS_ORIGINS=["*"]
JWT_SECRET=change-this-secret-in-production

# -- LLM Provider --
# Opciones: openai, anthropic, ollama
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
OLLAMA_BASE_URL=http://localhost:11434
MODEL_NAME=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
MAX_TOKENS=4096
TEMPERATURE=0.7

# -- Base de Datos --
DATABASE_URL=sqlite+aiosqlite:///./mentor.db
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
# Para producción con PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://mentor:mentor_secret@localhost:5432/mentor

# -- Redis --
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=3600

# -- Escalation Webhooks --
ESCALATION_WEBHOOK_URL=https://webhook.site/your-id

# -- Supabase (Opcional) --
# Si activas esto, asegúrate de que DATABASE_URL apunte a tu instancia de Supabase
USE_SUPABASE=false
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
# Ejemplo Connection String Supabase:
# DATABASE_URL=postgresql+asyncpg://postgres:password@db.yourproject.supabase.co:5432/postgres?sslmode=require

# -- Vector Store --
VECTOR_DB_PATH=./data/vectorstore
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# -- Integraciones (opcionales) --
SLACK_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=
